r rowheader\" scope=\"row\">30</th>\n<td class=\"data\">DIAGNOSIS_SUBCAT_DESC</td>\n<td class=\"data\">Char</td>\n<td class=\"r data\">24</td>\n<td class=\"data\">$24.</td>\n<td class=\"data\">$24.</td>\n</tr>\n<tr>\n<th class=\"r rowheader\" scope=\"row\">6</th>\n<td class=\"data\">DISCHARGED_TO</td>\n<td class=\"data\">Char</td>\n<td class=\"r data\">21</td>\n<td class=\"data\">$21.</td>\n<td class=\"data\">$21.</td>\n</tr>\n<tr>\n<th class=\"r rowheader\" scope=\"row\">9</th>\n<td class=\"data\">DISCH_NURSE_ID</td>\n<td class=\"data\">Num</td>\n<td class=\"r data\">8</td>\n<td class=\"data\">BEST12.</td>\n<td class=\"data\">BEST32.</td>\n</tr>\n<tr>\n<th class=\"r rowheader\" scope=\"row\">3</th>\n<td class=\"data\">DOCTOR</td>\n<td class=\"data\">Num</td>\n<td class=\"r data\">8</td>\n<td class=\"data\">BEST12.</td>\n<td class=\"data\">BEST32.</td>\n</tr>\n<tr>\n<th class=\"r rowheader\" scope=\"row\">26</th>\n<td class=\"data\">DRG_APR_CODE</td>\n<td class=\"data\">Num</td>\n<td class=\"r data\">8</td>\n<td class=\"data\">BEST12.</td>\n<td class=\"data\">BEST32.</td>\n</tr>\n<tr>\n<th class=\"r rowheader\" scope=\"row\">27</th>\n<td class=\"data\">DRG_APR_DESC</td>\n<td class=\"data\">Char</td>\n<td class=\"r data\">70</td>\n<td class=\"data\">$70.</td>\n<td class=\"data\">$70.</td>\n</tr>\n<tr>\n<th class=\"r rowheader\" scope=\"row\">28</th>\n<td class=\"data\">DRG_APR_SEVERITY</td>\n<td class=\"data\">Num</td>\n<td class=\"r data\">8</td>\n<td class=\"data\">BEST12.</td>\n<td class=\"data\">BEST32.</td>\n</tr>\n<tr>\n<th class=\"r rowheader\" scope=\"row\">37</th>\n<td class=\"data\">DX_CODE</td>\n<td class=\"data\">Num</td>\n<td class=\"r data\">8</td>\n<td class=\"data\">BEST12.</td>\n<td class=\"data\">BEST32.</td>\n</tr>\n<tr>\n<th class=\"r rowheader\" scope=\"row\">38</th>\n<td class=\"data\">DX_GROUP</td>\n<td class=\"data\">Char</td>\n<td class=\"r data\">69</td>\n<td class=\"data\">$69.</td>\n<td class=\"data\">$69.</td>\n</tr>\n<tr>\n<th class=\"r 