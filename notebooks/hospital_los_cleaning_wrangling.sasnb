ta\">FL</td>\n<td class=\"r data\">7602</td>\n</tr>\n<tr>\n<td class=\"r data\">33455</td>\n<td class=\"data\">GA</td>\n<td class=\"r data\">99</td>\n</tr>\n<tr>\n<td class=\"r data\">35242</td>\n<td class=\"data\">AL</td>\n<td class=\"r data\">287</td>\n</tr>\n<tr>\n<td class=\"r data\">35242</td>\n<td class=\"data\">FL</td>\n<td class=\"r data\">47</td>\n</tr>\n<tr>\n<td class=\"r data\">36022</td>\n<td class=\"data\">AL</td>\n<td class=\"r data\">143</td>\n</tr>\n<tr>\n<td class=\"r data\">36022</td>\n<td class=\"data\">MS</td>\n<td class=\"r data\">71</td>\n</tr>\n<tr>\n<td class=\"r data\">76117</td>\n<td class=\"data\">IL</td>\n<td class=\"r data\">25</td>\n</tr>\n<tr>\n<td class=\"r data\">76117</td>\n<td class=\"data\">TX</td>\n<td class=\"r data\">66</td>\n</tr>\n</tbody>\n</table>\n</div>\n</div>\n</body>\n</html>\n","mime":"application/vnd.sas.ods.html5"},{"data":"[\n\t{\n\t\t\"line\": \"632  /** LOG_START_INDICATOR **/\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"633  title;footnote;ods _all_ close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"634  ods graphics on;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"635  ods html5(id=vscode) style=HTMLEncore options(bitmap_mode='inline' svg_mode='inline');\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: Writing HTML5(VSCODE) Body file: sashtml16.htm\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"636  %let _SASPROGRAMFILE =\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"636! %nrquote(%nrstr(/workspaces/myfolder/project/sasviya_challenge_2026/notebooks/hospital_los_cleaning_wrangling.sasnb));\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"637  /* inspect which ZIPs span multiple states */\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"638  proc sql;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"639      select ZIP, STATECODE, count(*) as n\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"640      from work.hospital_los_train\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"641      group by ZIP, STATECODE\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"642      having ZIP in (select ZIP from work.hospital_los_train\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"643                      group by ZIP having count(distinct STATECODE) > 1)\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"644      order by ZIP;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"645  quit;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: PROCEDURE SQL used (Total process time):\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      real time           0.09 seconds\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      cpu time            0.13 seconds\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      \",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"646  ;*';*\\\";*/;run;quit;ods html5(id=vscode) close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"647  \",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t}\n]","mime":"application/vnd.sas.compute.log.lines"}]}]},{"kind":2,"language":"sas","value":"/* for each ZIP, reassign STATECODE to the majority value - fixes minority-class corruption */\nproc sql;\n    create table work.zip_majority_state as\n    select ZIP, STATECODE, count(*) as n\n    from work.hospital_los_train\n    group by ZIP, STATECODE;\nquit;\n\nproc sort data = work.zip_majority_state;\n    by ZIP descending n;\nrun;\n\ndata work.zip_majority_state;\n    set work.zip_majority_state;\n    by ZIP;\n    if first.ZIP;\n    keep ZIP STATECODE;\n    rename STATECODE = STATECODE_corrected;\nrun;\n\n/* write to a NEW table name instead of overwriting the source */\nproc sql;\n    create table work.hospital_los_train_fixed as\n    select a.*, b.STATECODE_corrected\n    from work.hospital_los_train a\n    left join work.zip_majority_state b\n    on a.ZIP = b.ZIP;\nquit;\n\ndata work.hospital_los_train_fixed;\n    set work.hospital_los_train_fixed;\n    drop STATECODE;\n    rename STATECODE_corrected = STATECODE;\nrun;\n\n/* now safely replace the original with the fixed version */\ndata work.hospital_los_train;\n    set work.hospital_los_train_fixed;\nrun;\n\nproc delete data = work.hospital_los_train_fixed;\nrun;","outputs":[{"items":[{"data":"[\n\t{\n\t\t\"line\": \"648  /** LOG_START_INDICATOR **/\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"649  title;footnote;ods _all_ close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"650  ods graphics on;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"651  ods html5(id=vscode) style=HTMLEncore options(bitmap_mode='inline' svg_mode='inline');\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: Writing HTML5(VSCODE) Body file: sashtml17.htm\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"652  %let _SASPROGRAMFILE =\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"652! %nrquote(%nrstr(/workspaces/myfolder/project/sasviya_challenge_2026/notebooks/hospital_los_cleaning_wrangling.sasnb));\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"653  /* for each ZIP, reassign STATECODE to the majority value - fixes minority-class co