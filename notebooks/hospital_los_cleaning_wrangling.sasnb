  from work.&dsname group by ZIP having n_county > 1);\n\n    select count(*) as inconsistent_state\n    from (select ZIP, count(distinct STATECODE) as n_state\n          from work.&dsname group by ZIP having n_state > 1);\nquit;\n%mend check_zip_consistency;","outputs":[{"items":[{"data":"[\n\t{\n\t\t\"line\": \"535  /** LOG_START_INDICATOR **/\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"536  title;footnote;ods _all_ close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"537  ods graphics on;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"538  ods html5(id=vscode) style=HTMLEncore options(bitmap_mode='inline' svg_mode='inline');\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: Writing HTML5(VSCODE) Body file: sashtml15.htm\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"539  %let _SASPROGRAMFILE =\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"539! %nrquote(%nrstr(/workspaces/myfolder/project/sasviya_challenge_2026/notebooks/hospital_los_cleaning_wrangling.sasnb));\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"540  /* ZIP / STATECODE correction\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"541  - Majority-vote mapping is learned from train ONLY, then applied to both\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"542  - avoids leaking test information into the correction logic */\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"543  \",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"544  /* check if ZIP maps 1:1 to CITY/COUNTY_NAME/STATECODE - if not, they're not redundant */\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"545  %macro check_zip_consistency(dsname);\",\n\t\t\"type\": \"source\",\n\t\t\"