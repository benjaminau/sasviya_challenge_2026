removal */\n    DIAGNOSIS_SUBCAT_DESC = prxchange('s/\\s{2,}/ /', -1, strip(DIAGNOSIS_SUBCAT_DESC));\n    DIAGNOSIS_LONG_DESC   = prxchange('s/\\s{2,}/ /', -1, strip(DIAGNOSIS_LONG_DESC));\n    MS_DRG_DESC           = prxchange('s/\\s{2,}/ /', -1, strip(MS_DRG_DESC));\nrun;\n\ndata work.hospital_los_test;\n    set work.hospital_los_test;\n    DIAGNOSIS_SUBCAT_DESC = prxchange('s/\\s*Hosp\\s+\\d+\\s*/ /i', -1, DIAGNOSIS_SUBCAT_DESC);\n    DIAGNOSIS_LONG_DESC   = prxchange('s/\\s*Hosp\\s+\\d+\\s*/ /i', -1, DIAGNOSIS_LONG_DESC);\n    MS_DRG_DESC           = prxchange('s/\\s*Hosp\\s+\\d+\\s*/ /i', -1, MS_DRG_DESC);\n\n    DIAGNOSIS_SUBCAT_DESC = prxchange('s/\\s{2,}/ /', -1, strip(DIAGNOSIS_SUBCAT_DESC));\n    DIAGNOSIS_LONG_DESC   = prxchange('s/\\s{2,}/ /', -1, strip(DIAGNOSIS_LONG_DESC));\n    MS_DRG_DESC           = prxchange('s/\\s{2,}/ /', -1, strip(MS_DRG_DESC));\nrun;","outputs":[{"items":[{"data":"[\n\t{\n\t\t\"line\": \"1147  /** LOG_START_INDICATOR **/\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1148  title;footnote;ods _all_ close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1149  ods graphics on;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1150  ods html5(id=vscode) style=HTMLEncore options(bitmap_mode='inline' svg_mode='inline');\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: Writing HTML5(VSCODE) Body file: sashtml31.htm\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1151  %let _SASPROGRAMFILE =\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1151! %nrquote(%nrstr(/workspaces/myfolder/project/sasviya_challenge_2026/notebooks/hospital_los_cleaning_wrangling.sasnb));\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1152  /* Remove embedded hospital references (e.g. \\\"CHRONIC Hosp 46 HEART\\\") from\",\n\t\t\"type\": \"source\",\n\t\