\\s*Hosp\\\\s+\\\\d+\\\\s*/ /i', -1, DIAGNOSIS_SUBCAT_DESC);\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"374      DIAGNOSIS_LONG_DESC   = prxchange('s/\\\\s*Hosp\\\\s+\\\\d+\\\\s*/ /i', -1, DIAGNOSIS_LONG_DESC);\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"375      MS_DRG_DESC           = prxchange('s/\\\\s*Hosp\\\\s+\\\\d+\\\\s*/ /i', -1, MS_DRG_DESC);\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"376      DIAGNOSIS_SUBCAT_DESC = prxchange('s/\\\\s{2,}/ /', -1, strip(DIAGNOSIS_SUBCAT_DESC));\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"377      DIAGNOSIS_LONG_DESC   = prxchange('s/\\\\s{2,}/ /', -1, strip(DIAGNOSIS_LONG_DESC));\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"378      MS_DRG_DESC           = prxchange('s/\\\\s{2,}/ /', -1, strip(MS_DRG_DESC));\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"379  \",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"380      /* PROCEDURE_SUBCAT_CODE/PROCEDURE_ICD_CODE were auto-imported as numeric;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"381         SAS's missing value (.) is what the csv's '.' placeholder became on import.\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"382         Convert to character explicitly since these become categorical labels ('NONE'),\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"383         not numeric codes, once \\\"no procedure\\\" is encoded. */\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"384      if missing(PROCEDURE_SUBCAT_CODE) then PROCEDURE_SUBCAT_CODE_char = 'NONE';\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"385      else PROCEDURE_SUBCAT_CODE_char = put(PROCEDURE_SUBCAT_CODE, best12.);\",\n\t\t\"type