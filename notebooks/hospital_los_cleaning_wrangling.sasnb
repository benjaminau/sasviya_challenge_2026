"note\",\n\t\t\"version\": 1\n\t}\n]","mime":"application/vnd.sas.compute.log.lines"}]}]},{"kind":2,"language":"sas","value":"/* build TRAIN-only majority-vote ZIP -> STATECODE mapping */\nproc sql;\n    create table work.zip_majority_state as\n    select ZIP, STATECODE, count(*) as n\n    from work.hospital_los_train\n    group by ZIP, STATECODE;\nquit;\n\nproc sort data = work.zip_majority_state;\n    by ZIP descending n;\nrun;\n\ndata work.zip_majority_state;\n    set work.zip_majority_state;\n    by ZIP;\n    if first.ZIP;\n    keep ZIP STATECODE;\n    rename STATECODE = STATECODE_corrected;\nrun;","outputs":[{"items":[{"data":"[\n\t{\n\t\t\"line\": \"665  /** LOG_START_INDICATOR **/\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"666  title;footnote;ods _all_ close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"667  ods graphics on;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"668  ods html5(id=vscode) style=HTMLEncore options(bitmap_mode='inline' svg_mode='inline');\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: Writing HTML5(VSCODE) Body file: sashtml23.htm\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"669  %let _SASPROGRAMFILE =\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"669! %nrquote(%nrstr(/workspaces/myfolder/project/sasviya_challenge_2026/notebooks/hospital_los_cleaning_wrangling.sasnb));\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"670  /* build TRAIN-only majority-vote ZIP -> STATECODE mapping */\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"671  proc sql;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"672      create table work.zip_majority_state as\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"673      select ZIP, STATECODE, count(