d>\n</tr>\n<tr>\n<th class=\"r rowheader\" scope=\"row\">34</th>\n<td class=\"data\">PROCEDURE_SUBCAT_DESC</td>\n<td class=\"data\">Char</td>\n<td class=\"r data\">26</td>\n<td class=\"data\">$26.</td>\n<td class=\"data\">$26.</td>\n</tr>\n<tr>\n<th class=\"r rowheader\" scope=\"row\">20</th>\n<td class=\"data\">RACE_CD</td>\n<td class=\"data\">Char</td>\n<td class=\"r data\">6</td>\n<td class=\"data\">$6.</td>\n<td class=\"data\">$6.</td>\n</tr>\n<tr>\n<th class=\"r rowheader\" scope=\"row\">19</th>\n<td class=\"data\">REGION</td>\n<td class=\"data\">Char</td>\n<td class=\"r data\">9</td>\n<td class=\"data\">$9.</td>\n<td class=\"data\">$9.</td>\n</tr>\n<tr>\n<th class=\"r rowheader\" scope=\"row\">7</th>\n<td class=\"data\">STANDARD_ORDERS_USED</td>\n<td class=\"data\">Char</td>\n<td class=\"r data\">1</td>\n<td class=\"data\">$1.</td>\n<td class=\"data\">$1.</td>\n</tr>\n<tr>\n<th class=\"r rowheader\" scope=\"row\">14</th>\n<td class=\"data\">STATECODE</td>\n<td class=\"data\">Char</td>\n<td class=\"r data\">2</td>\n<td class=\"data\">$2.</td>\n<td class=\"data\">$2.</td>\n</tr>\n<tr>\n<th class=\"r rowheader\" scope=\"row\">17</th>\n<td class=\"data\">X</td>\n<td class=\"data\">Num</td>\n<td class=\"r data\">8</td>\n<td class=\"data\">BEST12.</td>\n<td class=\"data\">BEST32.</td>\n</tr>\n<tr>\n<th class=\"r rowheader\" scope=\"row\">18</th>\n<td class=\"data\">Y</td>\n<td class=\"data\">Num</td>\n<td class=\"r data\">8</td>\n<td class=\"data\">BEST12.</td>\n<td class=\"data\">BEST32.</td>\n</tr>\n<tr>\n<th class=\"r rowheader\" scope=\"row\">13</th>\n<td class=\"data\">ZIP</td>\n<td class=\"data\">Num</td>\n<td class=\"r data\">8</td>\n<td class=\"data\">BEST12.</td>\n<td class=\"data\">BEST32.</td>\n</tr>\n</tbody>\n</table>\n</div>\n</div>\n</div>\n</body>\n</html>\n","mime":"application/vnd.sas.ods.html5"},{"data":"[\n\t{\n\t\t\"line\": \"338  /** LOG_START_INDICATOR **/\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"339  title;footnote;ods _all_ close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"340  ods graphics on;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"341  ods html5(id=vscode) style=HTMLEncore options(bitmap_mode='inline' svg_mode='inline');\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: Writing HTML5(VSCODE) Body file: sashtml2.htm\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"342  %let _SASPROGRAMFILE =\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"342! %nrquote(%nrstr(/workspaces/myfolder/project/sasviya_challenge_2026/notebooks/hospital_los_cleaning_wrangling.sasnb));\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"343  proc contents data = work.hospital_los_test;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"344  run;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: PROCEDURE CONTENTS used (Total process time):\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      real time           0.05 seconds\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      cpu time            0.05 seconds\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      \",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"345  ;*';*\\\";*/;run;quit;ods html5(id=vscode) close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"346  \",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t}\n]","mime":"application/vnd.sas.compute.log.lines"}]}]},{"kind":2,"language":"sas","value":"/* cleaning macro (applies identically to train/test)\n- Consolidates: drop DX_CODE, fix DEPARTMENT corruption, strip embedded\n- \"Hosp NN\" text from description fields, recode procedure \"no procedure\"\n- category, convert STANDARD_ORDERS_USED to numeric, add rule-based flags */\n%macro clean_data(dsname);\n\ndata work.&dsname;\n    set work.&dsname(drop=DX_CODE);  /* confirmed pure duplicate of DIAGNOSIS_ICD_CODE (0 inconsistent mappings) */\n\n    length PROCEDURE_SUBCAT_CODE_char PROCEDURE_ICD_CODE_char $20;\n    length PROCEDURE_SUBCAT_DESC_clean PROCEDURE_LONG_DESC_clean $100;\n\n    /* DEPARTMENT contains corrupted 'Hosp 39' values, spread proportionally across\n       all 39 hospitals - not tied to one source, so treat as Unknown rather than impute */\n    if DEPARTMENT = 'Hosp 39' then DEPARTMENT = 'Unknown';\n\n    /* remove embedded hospital references (e.g. \"CHRONIC Hosp 46 HEART\") from\n       description fields where hospital IDs leaked in during data export,\n       then collapse any resulting double spaces */\n    DIAGNOSIS_SUBCAT_DESC = prxchange('s/\\s*Hosp\\s+\\d+\\s*/ /i', -1, DIAGNOSIS_SUBCAT_DESC);\n    DIAGNOSIS_LONG_DESC   = prxchange('s/\\s*Hosp\\s+\\d+\\s*/ /i', -1, DIAGNOSIS_LONG_DESC);\n    MS_DRG_DESC           = prxchange('s/\\s*Hosp\\s+\\d+\\s*/ /i', -1, MS_DRG_DESC);\n    DIAGNOSIS_SUBCAT_DESC = prxchange('s/\\s{2,}/ /', -1, strip(DIAGNOSIS_SUBCAT_DESC));\n    DIAGNOSIS_LONG_DESC   = prxchange('s/\\s{2,}/ /', -1, strip(DIAGNOSIS_LONG_DESC));\n    MS_DRG_DESC           = prxchange('s/\\s{2,}/ /', -1, strip(MS_DRG_DESC));\n\n    /* PROCEDURE_SUBCAT_CODE/PROCEDURE_ICD_CODE were auto-imported as numeric;\n       SAS's missing value (.) is what the csv's '.' placeholder became on import.\n       Convert to character explicitly since these become categorical labels ('NONE'),\n       not numeric codes, once \"no procedure\" is encoded. */\n    if missing(PROCEDURE_SUBCAT_CODE) then PROCEDURE_SUBCAT_CODE_char = 'NONE';\n    else PROCEDURE_SUBCAT_CODE_char = put(PROCEDURE_SUBCAT_CODE, best12.);\n\n    if missing(PROCEDURE_ICD_CODE) then PROCEDURE_ICD_CODE_char = 'NONE';\n    else PROCEDURE_ICD_CODE_char = put(PROCEDURE_ICD_CODE, best12.);\n\n    if missing(PROCEDURE_SUBCAT_DESC) then PROCEDURE_SUBCAT_DESC_clean = 'No procedure performed';\n    else PROCEDURE_SUBCAT_DESC_clean = PROCEDURE_SUBCAT_DESC;\n\n    if missing(PROCEDURE_LONG_DESC) then PROCEDURE_LONG_DESC_clean = 'No procedure performed';\n    else PROCEDURE_LONG_DESC_clean = PROCEDURE_LONG_DESC;\n\n    drop PROCEDURE_SUBCAT_CODE PROCEDURE_ICD_CODE PROCEDURE_SUBCAT_DESC PROCEDURE_LONG_DESC;\n    rename PROCEDURE_SUBCAT_CODE_char = PROCEDURE_SUBCAT_CODE\n           PROCEDURE_ICD_CODE_char = PROCEDURE_ICD_CODE\n           PROCEDURE_SUBCAT_DESC_clean = PROCEDURE_SUBCAT_DESC\n           PROCEDURE_LONG_DESC_clean = PROCEDURE_LONG_DESC;\n\n    /* explicit flag - likely informative on its own for ADMIT_LOS */\n    had_procedure = (PROCEDURE_ICD_CODE_char ne 'NONE');\n\n    /* convert STANDARD_ORDERS_USED from Y/N text to 1/0 numeric,\n       consistent with ORDER_SET_USED which is already numeric */\n    STANDARD_ORDERS_USED_num = (STANDARD_ORDERS_USED = 'Y');\n    drop STANDARD_ORDERS_USED;\n    rename STANDARD_ORDERS_USED_num = STANDARD_ORDERS_USED;\n\n    /* rule-based derived features:\n       - high_severity_flag: top severity level (4 is max, confirmed from EDA range check)\n       - chronic_burden: combines chronic conditions + comorbidity index into one signal\n       - is_weekend_month/season proxies not available (no admit date), so seasonality\n         comes only from ADMIT_MTH directly */\n    high_severity_flag = (DRG_APR_SEVERITY = 4);\n    chronic_burden = NUM_CHRONIC_COND + COMORBIDITY_INDEX;\nrun;\n\n%mend clean_data;","outputs":[{"items":[{"data":"[\n\t{\n\t\t\"line\": \"347  /** LOG_START_INDICATOR **/\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"348  title;footnote;ods _all_ close;\",\n\t\t\"type\": \"source\"