export */\ndata work.hospital_los_train;\n    set work.hospital_los_train;\n    DIAGNOSIS_SUBCAT_DESC = prxchange('s/\\s*Hosp\\s+\\d+\\s*/ /i', -1, DIAGNOSIS_SUBCAT_DESC);\n    DIAGNOSIS_LONG_DESC   = prxchange('s/\\s*Hosp\\s+\\d+\\s*/ /i', -1, DIAGNOSIS_LONG_DESC);\n    MS_DRG_DESC           = prxchange('s/\\s*Hosp\\s+\\d+\\s*/ /i', -1, MS_DRG_DESC);\n\n    /* collapse any resulting double spaces from the removal */\n    DIAGNOSIS_SUBCAT_DESC = prxchange('s/\\s{2,}/ /', -1, strip(DIAGNOSIS_SUBCAT_DESC));\n    DIAGNOSIS_LONG_DESC   = prxchange('s/\\s{2,}/ /', -1, strip(DIAGNOSIS_LONG_DESC));\n    MS_DRG_DESC           = prxchange('s/\\s{2,}/ /', -1, strip(MS_DRG_DESC));\nrun;\n\ndata work.hospital_los_test;\n    set work.hospital_los_test;\n    DIAGNOSIS_SUBCAT_DESC = prxchange('s/\\s*Hosp\\s+\\d+\\s*/ /i', -1, DIAGNOSIS_SUBCAT_DESC);\n    DIAGNOSIS_LONG_DESC   = prxchange('s/\\s*Hosp\\s+\\d+\\s*/ /i', -1, DIAGNOSIS_LONG_DESC);\n    MS_DRG_DESC           = prxchange('s/\\s*Hosp\\s+\\d+\\s*/ /i', -1, MS_DRG_DESC);\n\n    DIAGNOSIS_SUBCAT_DESC = prxchange('s/\\s{2,}/ /', -1, strip(DIAGNOSIS_SUBCAT_DESC));\n    DIAGNOSIS_LONG_DESC   = prxchange('s/\\s{2,}/ /', -1, strip(DIAGNOSIS_LONG_DESC));\n    MS_DRG_DESC           = prxchange('s/\\s{2,}/ /', -1, strip(MS_DRG_DESC));\nrun;","outputs":[{"items":[{"data":"[\n\t{\n\t\t\"line\": \"380  /** LOG_START_INDICATOR **/\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"381  title;footnote;ods _all_ close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"382  ods graphics on;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"383  ods html5(id=vscode) style=HTMLEncore options(bitmap_mode='inline' svg_mode='inline');\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: Writing HTML5(VSCODE) Body file: sashtml5.htm\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"384  %let _SASPROGRAMFILE 