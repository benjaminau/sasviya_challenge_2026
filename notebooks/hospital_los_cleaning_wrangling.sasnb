>VA</td>\n<td class=\"r data\">137</td>\n</tr>\n<tr>\n<td class=\"r data\">30296</td>\n<td class=\"data\">GA</td>\n<td class=\"r data\">181</td>\n</tr>\n<tr>\n<td class=\"r data\">31404</td>\n<td class=\"data\">GA</td>\n<td class=\"r data\">579</td>\n</tr>\n<tr>\n<td class=\"r data\">33444</td>\n<td class=\"data\">FL</td>\n<td class=\"r data\">6529</td>\n</tr>\n<tr>\n<td class=\"r data\">33455</td>\n<td class=\"data\">FL</td>\n<td class=\"r data\">7701</td>\n</tr>\n</tbody>\n</table>\n</div>\n</div>\n</body>\n</html>\n","mime":"application/vnd.sas.ods.html5"},{"data":"[\n\t{\n\t\t\"line\": \"1846  /** LOG_START_INDICATOR **/\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1847  title;footnote;ods _all_ close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1848  ods graphics on;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1849  ods html5(id=vscode) style=HTMLEncore options(bitmap_mode='inline' svg_mode='inline');\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: Writing HTML5(VSCODE) Body file: sashtml63.htm\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1850  %let _SASPROGRAMFILE =\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1850! %nrquote(%nrstr(/workspaces/myfolder/project/sasviya_challenge_2026/notebooks/hospital_los_cleaning_wrangling.sasnb));\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1851  proc sql;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1852      select ZIP, STATECODE, count(*) as n\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1853      from work.hospital_los_train\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1854      group by ZIP, STATECODE\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1855      having ZIP in (22943, 30296, 31404, 33444, 33455)\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1856      order by ZIP;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1857  quit;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: PROCEDURE SQL used (Total process time):\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      real time           0.04 seconds\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      cpu time            0.06 seconds\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      \",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1858  ;*';*\\\";*/;run;quit;ods html5(id=vscode) close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1859  \",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t}\n]","mime":"application/vnd.sas.compute.log.lines"}]}]},{"kind":2,"language":"sas","value":"/* check if ZIP maps 1:1 to CITY/COUNTY_NAME/STATECODE - if so, some may be redundant */\nproc sql;\n    select count(*) as inconsistent_city\n    from (select ZIP, count(distinct CITY) as n_city\n          from work.hospital_los_test\n          group by ZIP\n          having n_city > 1);\n\n    select count(*) as inconsistent_county\n    from (select ZIP, count(distinct COUNTY_NAME) as n_county\n          from work.hospital_los_test\n          group by ZIP\n          having n_county > 1);\n\n    select count(*) as inconsistent_state\n    from (select ZIP, count(distinct STATECODE) as n_state\n          from work.hospital_los_test\n          group by ZIP\n          having n_state > 1);\nquit;","outputs":[{"items":[{"data":"<!DOCTYPE html>\n<html lang=\"en\" xml:lang=\"en\" xmlns=\"http://www.w3.