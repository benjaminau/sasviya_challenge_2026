y AMT', Helvetica, Helv;\n    font-size: 9pt;\n    font-style: normal;\n    font-weight: bold;\n}\n.warncontent {\n    background-color: #fafbfe;\n    color: #112277;\n    font-family: 'Anova UI', Arial, 'Albany AMT', Helvetica, Helv;\n    font-size: 9pt;\n    font-style: normal;\n    font-weight: normal;\n}\n.warncontentfixed {\n    background-color: #fafbfe;\n    color: #112277;\n    font-family: 'Courier New', Courier;\n    font-size: 8pt;\n    font-style: normal;\n    font-weight: normal;\n}\n/*]]>*/\n</style>\n</head>\n<body class=\"c body\">\n<div style=\"padding-bottom: 8px; padding-top: 1px\">\n<div id=\"IDX\" style=\"padding-bottom: 8px; padding-top: 1px\">\n</div>\n</div>\n</body>\n</html>\n","mime":"application/vnd.sas.ods.html5"},{"data":"[\n\t{\n\t\t\"line\": \"1903  /** LOG_START_INDICATOR **/\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1904  title;footnote;ods _all_ close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1905  ods graphics on;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1906  ods html5(id=vscode) style=HTMLEncore options(bitmap_mode='inline' svg_mode='inline');\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: Writing HTML5(VSCODE) Body file: sashtml66.htm\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1907  %let _SASPROGRAMFILE =\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1907! %nrquote(%nrstr(/workspaces/myfolder/project/sasviya_challenge_2026/notebooks/hospital_los_cleaning_wrangling.sasnb));\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1908  /* inspect which ZIPs span multiple states */\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1909  proc sql;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1910      select ZIP, STATECODE, count(*) as n\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1911      from work.hospital_los_train\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1912      group by ZIP, STATECODE\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1913      having ZIP in (select ZIP from work.hospital_los_train\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1914                      group by ZIP having count(distinct STATECODE) > 1)\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1915      order by ZIP;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: No rows were selected.\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"68                                                         The SAS System                          Friday, July 17, 2026 12:14:00 AM\",\n\t\t\"type\": \"title\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"\",\n\t\t\"type\": \"title\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1916  quit;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: PROCEDURE SQL used (Total process time):\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      real time           0.11 seconds\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      cpu time            0.11 seconds\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      \",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1917  ;*';*\\\";*/;run;quit;ods html5(id=vscode) close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1918  \",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t}\n]","mime":"application/vnd.sas.compute.log.lines"}]}]},{"kind":2,"language":"sas","value":"/* for each ZIP, reassign STATECODE to the majority value - fixes minority-class corruption */\nproc sql;\n    create table work.zip_majority_state as\n    select ZIP, STATECODE, count(*) as n\n    from work.hospital_los_train\n    group by ZIP, STATECODE;\nquit;\n\nproc sort data = work.zip_majority_state;\n    by ZIP descending n;\nrun;\n\ndata work.zip_majority_state;\n    set work.zip_majority_state;\n    by ZIP;\n    if first.ZIP;\n    keep ZIP STATECODE;\n    rename STATECODE = STATECODE_corrected;\nrun;\n\n/* write to a NEW table name instead of overwriting the source */\nproc sql;\n    create table work.hospital_los_train_fixed as\n    select a.*, b.STATECODE_corrected\n    from work.hospital_los_train a\n    left join work.zip_majority_state b\n    on a.ZIP = b.ZIP;\nquit;\n\ndata work.hospital_los_train_fixed;\n    set work.hospital_los_train_fixed;\n    drop STATECODE;\n    rename STATECODE_corrected = STATECODE;\nrun;\n\n/* now safely replace the original with the fixed version */\ndata work.hospital_los_train;\n    set work.hospital_los_train_fixed;\nrun;\n\nproc delete data = work.hospital_los_train_fixed;\nrun;","outputs":[{"items":[{"data":"[\n\t{\n\t\t\"line\": \"1797  /** LOG_START_INDICATOR **/\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1798  title;footnote;ods _all_ close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1799  ods graphics on;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1800  ods html5(id=vscode) style=HTMLEncore options(bitmap_mode='inline' svg_mode='inline');\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: Writing HTML5(VSCODE) Body file: sashtml62.htm\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1801  %let _SASPROGRAMFILE =\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"18