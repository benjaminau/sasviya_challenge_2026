.\n   Convert to character explicitly since these become categorical labels ('NONE'),\n   not numeric codes, once \"no procedure\" is encoded. */\ndata work.hospital_los_train;\n    set work.hospital_los_train;\n    length PROCEDURE_SUBCAT_CODE_char PROCEDURE_ICD_CODE_char $20;\n    length PROCEDURE_SUBCAT_DESC_clean PROCEDURE_LONG_DESC_clean $100;\n\n    if missing(PROCEDURE_SUBCAT_CODE) then PROCEDURE_SUBCAT_CODE_char = 'NONE';\n    else PROCEDURE_SUBCAT_CODE_char = put(PROCEDURE_SUBCAT_CODE, best12.);\n\n    if missing(PROCEDURE_ICD_CODE) then PROCEDURE_ICD_CODE_char = 'NONE';\n    else PROCEDURE_ICD_CODE_char = put(PROCEDURE_ICD_CODE, best12.);\n\n    if missing(PROCEDURE_SUBCAT_DESC) then PROCEDURE_SUBCAT_DESC_clean = 'No procedure performed';\n    else PROCEDURE_SUBCAT_DESC_clean = PROCEDURE_SUBCAT_DESC;\n\n    if missing(PROCEDURE_LONG_DESC) then PROCEDURE_LONG_DESC_clean = 'No procedure performed';\n    else PROCEDURE_LONG_DESC_clean = PROCEDURE_LONG_DESC;\n\n    drop PROCEDURE_SUBCAT_CODE PROCEDURE_ICD_CODE PROCEDURE_SUBCAT_DESC PROCEDURE_LONG_DESC;\n    rename PROCEDURE_SUBCAT_CODE_char = PROCEDURE_SUBCAT_CODE\n           PROCEDURE_ICD_CODE_char = PROCEDURE_ICD_CODE\n           PROCEDURE_SUBCAT_DESC_clean = PROCEDURE_SUBCAT_DESC\n           PROCEDURE_LONG_DESC_clean = PROCEDURE_LONG_DESC;\n\n    /* explicit flag - likely informative on its own for ADMIT_LOS */\n    had_procedure = (PROCEDURE_ICD_CODE_char ne 'NONE');\nrun;\n\ndata work.hospital_los_test;\n    set work.hospital_los_test;\n    length PROCEDURE_SUBCAT_CODE_char PROCEDURE_ICD_CODE_char $20;\n    length PROCEDURE_SUBCAT_DESC_clean PROCEDURE_LONG_DESC_clean $100;\n\n    if missing(PROCEDURE_SUBCAT_CODE) then PROCEDURE_SUBCAT_CODE_char = 'NONE';\n    else PROCEDURE_SUBCAT_CODE_char = put(PROCEDURE_SUBCAT_CODE, best12.);\n\n    if missing(PROCEDURE_ICD_CODE) then PROCEDURE_ICD_CODE_char = 'NONE';\n    else PROCEDURE_ICD_CODE_char = put(PROCEDURE_ICD_CODE, best12.);\n\n    if missing(PROCEDURE_SUBCAT_DESC) then PROCEDURE_SUBCAT_DESC_clean = 'No procedure performed';\n    else PROCEDURE_SUBCAT_DESC_clean = PROCEDURE_SUBCAT_DESC;\n\n    if missing(PROCEDURE_LONG_DESC) then PROCEDURE_LONG_DESC_clean = 'No procedure performed';\n    else PROCEDURE_LONG_DESC_clean = PROCEDURE_LONG_DESC;\n\n    drop PROCEDURE_SUBCAT_CODE PROCEDURE_ICD_CODE PROCEDURE_SUBCAT_DESC PROCEDURE_LONG_DESC;\n    rename PROCEDURE_SUBCAT_CODE_char = PROCEDURE_SUBCAT_CODE\n           PROCEDURE_ICD_CODE_char = PROCEDURE_ICD_CODE\n           PROCEDURE_SUBCAT_DESC_clean = PROCEDURE_SUBCAT_DESC\n           PROCEDURE_LONG_DESC_clean = PROCEDURE_LONG_DESC;\n\n    had_procedure = (PROCEDURE_ICD_CODE_char ne 'NONE');\nrun;","outputs":[{"items":[{"data":"[\n\t{\n\t\t\"line\": \"1228  /** LOG_START_INDICATOR **/\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1229  title;footnote;ods _all_ close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1230  ods graphics on;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1231  ods html5(id=vscode) style=HTMLEncore options(bitmap_mode='inline' svg_mode='inline');\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: Writing HTML5(VSCODE) Body file: sashtml33.htm\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1232  %let _SASPROGRAMFILE =\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1232! %nrquote(%nrstr(/workspaces/myfolder/project/sasviya_challenge_2026/notebooks/hospital_los_cleaning_wrangling.sasnb));\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1233  /* PROCEDURE_SUBCAT_CODE/PROCEDURE_ICD_CODE were auto-imported as numeric;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"1234     SAS's missing value (.) is what the CSV's '.' placeholder became on import.\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\